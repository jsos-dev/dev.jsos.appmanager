{
  "name": "app-manager",
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server.js",
    "git:tag": "node -e \"const v=require('./package.json').version;const{execSync}=require('child_process');execSync('git tag v'+v+' && git push origin v'+v,{stdio:'inherit'});console.log('Tagged and pushed v'+v)\"",
    "jsh:install": "(cd node_modules >/dev/null 2>&1) || npm install",
    "jsh:start": "node server.js"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.0.0"
  },
  "jsos": {
    "id": "dev.jsos.appmanager",
    "name": {
      "en": "App Manager",
      "zh-CN": "应用管理"
    },
    "description": {
      "en": "Manage installed applications",
      "zh-CN": "管理系统中的应用"
    },
    "icon": "icon.svg",
    "startCommand": "npm run jsh:start",
    "installCommand": "npm run jsh:install"
  }
}
